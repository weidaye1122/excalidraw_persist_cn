{
  "name": "excalidraw-persist",
  "version": "0.18.0-persist.7",
  "description": "Self-hostable Excalidraw server-side persistence, and multi-boards",
  "private": true,
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" && pnpm -r run format",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "excalidraw",
    "drawing"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "nanoid@<3.3.8": ">=3.3.8",
      "nanoid": ">=5.0.9",
      "lodash-es": ">=4.18.1",
      "dompurify": ">=3.3.3",
      "brace-expansion": ">=5.0.5",
      "@tootallnate/once": ">=3.0.1",
      "mermaid": ">=10.9.4"
    }
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
} 
